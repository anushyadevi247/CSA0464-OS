#include <stdio.h>
int main() {
    int n, i, tq, rem[10], bt[10], wt[10], tat[10];
    int time = 0, done;
    scanf("%d", &n);
    for(i = 0; i < n; i++) {
        scanf("%d", &bt[i]);
        rem[i] = bt[i];
    }
    scanf("%d", &tq);
    do {
        done = 1;
        for(i = 0; i < n; i++) {
            if(rem[i] > 0) {
                done = 0;
                if(rem[i] > tq) {
                    time += tq;
                    rem[i] -= tq;
                } else {
                    time += rem[i];
                    wt[i] = time - bt[i];
                    rem[i] = 0;
                }
            }
        }
    } while(!done);
    for(i = 0; i < n; i++) {
        tat[i] = bt[i] + wt[i];
        printf("P%d\tWT=%d\tTAT=%d\n", i + 1, wt[i], tat[i]);
    }
    return 0;
}

