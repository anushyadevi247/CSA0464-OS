#include <stdio.h>
#include <stdlib.h>
int main()
{
    int requests[100], n, head, i;
    int totalSeek = 0;
    printf("Enter number of requests: ");
    scanf("%d", &n);
    printf("Enter request queue: ");
    for(i = 0; i < n; i++)
        scanf("%d", &requests[i]);
    printf("Enter initial head position: ");
    scanf("%d", &head);
    printf("\nSeek Sequence: %d", head);
    for(i = 0; i < n; i++)
    {
        totalSeek += abs(head - requests[i]);
        head = requests[i];
        printf(" -> %d", head);
    }
    printf("\n\nTotal Head Movement = %d\n", totalSeek);
    return 0;
}


INPUT
Enter number of requests: 8
Enter request queue:
98 183 37 122 14 124 65 67
Enter initial head position: 53


OUTPUT
Seek Sequence: 53 -> 98 -> 183 -> 37 -> 122 -> 14 -> 124 -> 65 -> 67
Total Head Movement = 640
