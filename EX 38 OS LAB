#include <stdio.h>
#include <stdlib.h>
void sort(int arr[], int n)
{
    int i, j, temp;
    for(i = 0; i < n - 1; i++)
    {
        for(j = 0; j < n - i - 1; j++)
        {
            if(arr[j] > arr[j + 1])
            {
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}
int main()
{
    int req[100], n, head, diskSize;
    int i, pos, totalSeek = 0;
    int direction;
    printf("Enter number of requests: ");
    scanf("%d", &n);
    printf("Enter request queue: ");
    for(i = 0; i < n; i++)
        scanf("%d", &req[i]);
    printf("Enter initial head position: ");
    scanf("%d", &head);
    printf("Enter disk size: ");
    scanf("%d", &diskSize);
    printf("Enter direction (1 for high, 0 for low): ");
    scanf("%d", &direction);
    sort(req, n);
    for(i = 0; i < n; i++)
    {
        if(req[i] >= head)
        {
            pos = i;
            break;
        }
    }
    printf("\nSeek Sequence: %d", head);
    if(direction == 1)
    {
        for(i = pos; i < n; i++)
        {
            totalSeek += abs(head - req[i]);
            head = req[i];
            printf(" -> %d", head);
        }
        totalSeek += abs(head - (diskSize - 1));
        head = diskSize - 1;
        for(i = pos - 1; i >= 0; i--)
        {
            totalSeek += abs(head - req[i]);
            head = req[i];
            printf(" -> %d", head);
        }
    }
    else
    {
        for(i = pos - 1; i >= 0; i--)
        {
            totalSeek += abs(head - req[i]);
            head = req[i];
            printf(" -> %d", head);
        }
        totalSeek += abs(head - 0);
        head = 0;
        for(i = pos; i < n; i++)
        {
            totalSeek += abs(head - req[i]);
            head = req[i];
            printf(" -> %d", head);
        }
    }
    printf("\n\nTotal Head Movement = %d\n", totalSeek);
    return 0;
}


INPUT
Enter number of requests: 8
Enter request queue:
98 183 37 122 14 124 65 67
Enter initial head position: 53
Enter disk size: 200
Enter direction (1 for high, 0 for low): 1


OUTPUT
Seek Sequence: 53 -> 65 -> 67 -> 98 -> 122 -> 124 -> 183 -> 37 -> 14
Total Head Movement = 331
