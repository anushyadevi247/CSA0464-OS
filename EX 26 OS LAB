#include <stdio.h>
#include <stdlib.h>
int main()
{
    FILE *fp;
    char data[100], appendData[100], ch;
    fp = fopen("sample.txt", "w");
    if (fp == NULL)
    {
        printf("Error creating file.\n");
        return 1;
    }
    printf("Enter text to write into file: ");
    scanf(" %[^\n]", data);
    fprintf(fp, "%s\n", data);
    fclose(fp);
    printf("\nData written successfully.\n");
    fp = fopen("sample.txt", "r");
    if (fp == NULL)
    {
        printf("Error opening file.\n");
        return 1;
    }
    printf("\nContents of file:\n");
    while ((ch = fgetc(fp)) != EOF)
    {
        putchar(ch);
    }
    fclose(fp);
    fp = fopen("sample.txt", "a");
    printf("\n\nEnter text to append: ");
    scanf(" %[^\n]", appendData);
    fprintf(fp, "%s\n", appendData);
    fclose(fp);
    fp = fopen("sample.txt", "r");
    printf("\nUpdated file contents:\n");
    while ((ch = fgetc(fp)) != EOF)
    {
        putchar(ch);
    }
    fclose(fp);
    return 0;
}



