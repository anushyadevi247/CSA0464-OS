#include <stdio.h>
#include <dirent.h>
int main()
{
    DIR *d;
    struct dirent *dir;
    d = opendir(".");
    if (d == NULL)
    {
        printf("Unable to open directory.\n");
        return 1;
    }
    printf("Files and Directories:\n");

    while ((dir = readdir(d)) != NULL)
    {
        printf("%s\n", dir->d_name);
    }

    closedir(d);

    return 0;
}


