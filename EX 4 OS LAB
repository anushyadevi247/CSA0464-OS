#include <stdio.h>
int main() {
    int n, i, j, bt[10], wt[10], tat[10], temp;
    float awt = 0, atat = 0;
    scanf("%d", &n);
    for(i = 0; i < n; i++)
        scanf("%d", &bt[i]);
    for(i = 0; i < n - 1; i++)
        for(j = i + 1; j < n; j++)
            if(bt[i] > bt[j]) {
                temp = bt[i];
                bt[i] = bt[j];
                bt[j] = temp;
            }
    wt[0] = 0;
    for(i = 1; i < n; i++)
        wt[i] = wt[i - 1] + bt[i - 1];
    for(i = 0; i < n; i++) {
        tat[i] = wt[i] + bt[i];
        awt += wt[i];
        atat += tat[i];
        printf("P%d\t%d\t%d\t%d\n", i + 1, bt[i], wt[i], tat[i]);
    }
    printf("Average WT = %.2f\n", awt / n);
    printf("Average TAT = %.2f\n", atat / n);
    return 0;
}

INPUT
4
6 8 7 3

OUTPUT
P1  3  0   3
P2  6  3   9
P3  7  9   16
P4  8  16  24

Average WT = 7.00
Average TAT = 13.00



