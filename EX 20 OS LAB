#include <stdio.h>
int main()
{
    int readcount = 0;
    printf("Reader 1 is Reading\n");
    readcount++;
    printf("Reader 2 is Reading\n");
    readcount++;
    printf("Writer is Writing\n");
    readcount--;
    printf("Reader 1 Finished Reading\n");
    readcount--;
    printf("Reader 2 Finished Reading\n");
    return 0;
}


INPUT
No Input

OUTPUT
Reader 1 is Reading
Reader 2 is Reading
Writer is Writing
Reader 1 Finished Reading
Reader 2 Finished Reading



